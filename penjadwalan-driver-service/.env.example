APP_NAME="Penjadwalan-Driver-Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=db_schedule
DB_USERNAME=root
DB_PASSWORD=secret

CACHE_STORE=file
SESSION_DRIVER=file
LOG_CHANNEL=stderr

L5_SWAGGER_GENERATE_ALWAYS=true

# ============================================================
# IAE SSO — Server Nyata (dari URL dan Akun Tugas IAE.pdf)
# URL: https://iae-sso.virtualfri.id
# ============================================================
SSO_BASE_URL=https://iae-sso.virtualfri.id
SSO_JWKS_URL=https://iae-sso.virtualfri.id/api/v1/auth/jwks
SSO_TOKEN_URL=https://iae-sso.virtualfri.id/api/v1/auth/token

# Akun Warga (XX = nomor absen, misal: warga35@ktp.iae.id untuk absen 35)
SSO_USER_EMAIL=warga35@ktp.iae.id
SSO_USER_PASSWORD=KtpDigital2026!

# M2M API Key (Machine-to-Machine)
SSO_M2M_API_KEY=KEY-MHS-270

# ============================================================
# IAE SOAP Audit — Server Nyata
# ============================================================
SOAP_AUDIT_ENDPOINT=https://iae-sso.virtualfri.id/soap/v1/audit
SOAP_AUDIT_NAMESPACE=http://iae.central/audit
IAE_TEAM_ID=TEAM-07

# ============================================================
# IAE Message Broker (HTTP REST, bukan AMQP langsung)
# ============================================================
MESSAGE_PUBLISH_URL=https://iae-sso.virtualfri.id/api/v1/messages/publish
MESSAGE_EXCHANGE=iae.central.exchange
